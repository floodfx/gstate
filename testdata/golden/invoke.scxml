<?xml version="1.0" encoding="UTF-8"?>
<scxml xmlns="http://www.w3.org/2005/07/scxml" version="1.0" name="invoke" initial="loading">
  <final id="failure"></final>
  <state id="loading">
    <transition event="done.invoke.loading" target="success"></transition>
    <transition event="error.platform" target="failure"></transition>
    <invoke id="loading"></invoke>
  </state>
  <final id="success"></final>
</scxml>
